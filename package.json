{
  "name": "claude-usage",
  "version": "0.1.0",
  "description": "Live terminal view of Claude.ai plan usage limits, reusing Claude Code's OAuth credentials.",
  "type": "module",
  "bin": {
    "claude-usage": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.tsx",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "install:global": "npm install -g .",
    "uninstall:global": "npm uninstall -g claude-usage"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "ink": "^5.0.1",
    "meow": "^13.2.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Simon Moxon",
  "license": "MIT"
}
